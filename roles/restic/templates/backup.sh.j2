#!/usr/bin/bash
{{ ansible_managed | comment }}

export RESTIC_CACHE_DIR="{{ restic_cache_dir }}"
export RESTIC_REPOSITORY="{{ restic_repo_path }}"
export RESTIC_PASSWORD="{{ restic_password }}"

export ADMIN_EMAIL="{{ restic_admin_email }}"

info() { printf "\n%s %s\n\n" "$( date )" "$*" >&2; }
trap 'echo $( date ) Backup interrupted >&2; exit 2' INT TERM

global_exit=0
backup_dir="{{ restic_dump_dir }}"
[[ ! -d "$backup_dir" ]] && mkdir -p "$backup_dir"

# Clean previous dumps
rm -rf "${backup_dir:?}"/*

info "Starting backup routine"

# ==========================================
# Application Dumps
# ==========================================

{% if restic_mariadb_backup %}
info "Running MariaDB dump..."
mkdir -p "$backup_dir/mariadb"
mariadb-backup --backup --target-dir="$backup_dir/mariadb" --socket={{ restic_mariadb_socket }}
if [ $? -ne 0 ]; then
    info "ERROR: MariaDB dump failed"
    global_exit=1
fi
{% endif %}

{% if restic_openldap_backup %}
info "Running OpenLDAP dump..."
mkdir -p "$backup_dir/openldap"

# Dump the main database
sudo /usr/sbin/slapcat -l "$backup_dir/openldap/data.ldif"
if [ $? -ne 0 ]; then
    info "ERROR: OpenLDAP data dump failed"
    global_exit=1
fi

# Dump the configuration database (cn=config)
sudo /usr/sbin/slapcat -n 0 -l "$backup_dir/openldap/config.ldif"
if [ $? -ne 0 ]; then
    info "ERROR: OpenLDAP config dump failed"
    global_exit=1
fi
{% endif %}

# ==========================================
# Restic Core Backup
# ==========================================

info "Running Restic backup..."
restic -o rclone.connections=2 backup \
{% for dir in restic_source_dirs %}
    "{{ dir }}" \
{% endfor %}
{% if restic_mariadb_backup or restic_openldap_backup %}
    "{{ restic_dump_dir }}" \
{% endif %}
    --exclude-file="{{ restic_home }}/excludes.txt"

restic_exit=$?
if [ ${restic_exit} -ne 0 ]; then
    info "ERROR: Restic backup command failed with exit code ${restic_exit}"
    global_exit=$(( global_exit > restic_exit ? global_exit : restic_exit ))
fi

# ==========================================
# Alerting & Cleanup
# ==========================================

if [ ${global_exit} -eq 0 ]; then
    info "Backup finished successfully"
else
    error_message="WARNING: Backup task failed on $(hostname) with exit code ${global_exit}. Please check the server logs immediately."
    info "${error_message}"

    {% if restic_admin_email | length > 0 %}
    # Send the email alert (Variable name fixed!)
    echo "${error_message}" | mail -s "Backup Alert: $(hostname) Failed" "${ADMIN_EMAIL}"
    {% endif %}
fi

exit ${global_exit}
