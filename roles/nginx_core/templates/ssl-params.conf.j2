{{ ansible_managed | comment }}

# Certificate paths
ssl_certificate     {{ nginx_core_tls_cert_path }};
ssl_certificate_key {{ nginx_core_tls_key_path }};

# TLS settings
ssl_protocols TLSv1.3;
ssl_ecdh_curve X25519MLKEM768:X25519:prime256v1:secp384r1;
ssl_prefer_server_ciphers off;

{% if nginx_core_enable_ocsp %}
# OCSP stapling
ssl_stapling on;
ssl_stapling_verify on;
resolver {{ nginx_core_resolver }} valid=300s;
resolver_timeout 5s;

ssl_trusted_certificate {{ nginx_core_tls_issuer_path }};
{% endif %}
