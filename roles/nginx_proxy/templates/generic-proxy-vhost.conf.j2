{{ ansible_managed | comment }}

{% if item.websockets | default(false) %}
map $http_upgrade $connection_upgrade {
  default upgrade;
  '' close;
}

{% endif %}
upstream {{ item.name }}_backend {
    server localhost:{{ item.upstream_port }};
}

{% if item.is_default | default(false) %}
server {
    listen 80 default_server;
	listen [::]:80 default_server;

	server_name _;

	return 308 https://$host$request_uri;
}

{% endif %}
server {
    listen [::]:443 ssl{% if item.is_default | default(false) %} default_server{% endif %};
    listen 443 ssl{% if item.is_default | default(false) %} default_server{% endif %};
    http2 on;

    server_name {{ item.domain }};
    include /etc/nginx/snippets/ssl-params.conf;

    location / {
        proxy_pass http://{{ item.name }}_backend;

        # Standard headers used by almost all proxies
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;

        # Conditionally added headers based on service requirements
{% if item.set_x_forwarded_for | default(true) %}
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
{% endif %}
{% if item.set_x_forwarded_proto | default(false) %}
        proxy_set_header X-Forwarded-Proto $scheme;
{% endif %}
{% if item.pass_request_headers | default(false) %}
        proxy_pass_request_headers on;
{% endif %}
{% if item.http_version_1_1 | default(false) or item.websockets | default(false) %}
        proxy_http_version 1.1;
{% endif %}
{% if item.websockets | default(false) %}
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $connection_upgrade;
{% endif %}
    }
}
