# {{ ansible_managed | comment }}
common:
  daemonize: true
  log_media: file
  log_level: info
  log_dir: /var/log/
  log_max_size: 20
  compress_logs: true
  log_max_files: 10

config_paths:
  config_dir: /etc/crowdsec/
  data_dir: /var/lib/crowdsec/data/
  simulation_path: /etc/crowdsec/simulation.yaml
  hub_dir: /etc/crowdsec/hub/
  index_path: /etc/crowdsec/hub/.index.json
  notification_dir: /etc/crowdsec/notifications/
  plugin_dir: /usr/lib/crowdsec/plugins/

crowdsec_service:
  acquisition_path: /etc/crowdsec/acquis.yaml
  acquisition_dir: /etc/crowdsec/acquis.d
  parser_routines: {{ crowdsec_parser_routines }}

cscli:
  output: human
  color: auto

db_config:
  log_level: info
  type: {{ crowdsec_db_type }}
  db_path: {{ crowdsec_db_path }}
  flush:
    max_items: {{ crowdsec_db_flush_max_items }}
    max_age: {{ crowdsec_db_flush_max_age }}

plugin_config:
  user: nobody
  group: nogroup

api:
  client:
    insecure_skip_verify: false
    credentials_path: /etc/crowdsec/local_api_credentials.yaml
{% if crowdsec_lapi_server %}
  server:
    log_level: info
    listen_uri: "[::]:8080"
    profiles_path: /etc/crowdsec/profiles.yaml
    console_path: /etc/crowdsec/console.yaml
    online_client:
      credentials_path: /etc/crowdsec/online_api_credentials.yaml
    trusted_ips:
      - 127.0.0.1
      - ::1
    auto_registration:
      enabled: true
      token: "{{ crowdsec_auto_registration_token }}"
      allowed_ranges:
        - {{ crowdsec_auto_registration_network }}
{% endif %}

prometheus:
  enabled: {{ crowdsec_prometheus_enabled | string | lower }}
  level: {{ crowdsec_prometheus_level }}
  listen_addr: "{{ crowdsec_prometheus_listen_addr }}"
  listen_port: {{ crowdsec_prometheus_listen_port }}

